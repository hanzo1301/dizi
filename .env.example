# Gallery photos – folder ID from the Drive URL:
# https://drive.google.com/drive/folders/<FOTKY_FOLDER_ID>
DRIVE_FOLDER_ID=
# or
FOTKY_FOLDER_ID=

# Upcoming events – event cover images from this folder (same account):
EVENTS_FOLDER_ID=

# Either use the same service account as other Google APIs, or a separate one for Drive.
# Share the Drive folder with the service account email (Viewer).

# Option A: Main Google credentials (if you use one account for everything)
# GOOGLE_PROJECT_ID=
# GOOGLE_PRIVATE_KEY_ID=
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_CLIENT_EMAIL=...@....iam.gserviceaccount.com
# GOOGLE_CLIENT_ID=

# Option B: Separate Drive-only credentials (optional)
# GOOGLE_DRIVE_PROJECT_ID=
# GOOGLE_DRIVE_PRIVATE_KEY_ID=
# GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_DRIVE_CLIENT_EMAIL=...@....iam.gserviceaccount.com
# GOOGLE_DRIVE_CLIENT_ID=
